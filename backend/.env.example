# Copy this file to .env and fill in the values
SECRET_KEY=change-this-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Local development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./barbershop.db

# Production (Supabase) — reemplaza con tu URL de Supabase
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Orígenes permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# En producción agregar la URL de Vercel:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://tu-app.vercel.app

SERPAPI_KEY=
